# Copy to `.env.local` for local development (never commit `.env.local`).
# Stage / production values should be set in the hosting platform or CI secrets.

# CIP API base URL (no trailing slash). Also used to allow Next.js image optimization.
# Stage example:
NEXT_PUBLIC_API_BASE_URL=http://141.11.250.83:7010/cip/api/v1
# Production example (replace with real host):
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com/cip/api/v1
